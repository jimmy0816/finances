---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const locale = 'en';
---
<BaseLayout title="Blog — Taiwan Financial Guides" locale={locale}>
  <section class="blog-hero">
    <div class="container">
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--color-accent);margin-bottom:16px;">Knowledge Base</div>
      <h1>Financial Blog</h1>
      <p style="font-size:15px;font-weight:300;color:rgba(255,255,255,0.6);max-width:480px;line-height:1.7;margin-top:16px;">Financial knowledge, calculator guides, Taiwan money management. No product sales — just helping you understand the numbers.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div style="padding:48px;text-align:center;border:0.5px solid var(--color-border);background:var(--color-bg-card);">
        <span style="font-size:48px;display:block;margin-bottom:16px;">📚</span>
        <h2 style="font-size:20px;font-weight:400;margin-bottom:12px;">Articles Coming Soon</h2>
        <p style="font-size:14px;color:var(--color-text-muted);font-weight:300;">Articles covering mortgages, retirement planning, and salary tax are in preparation.</p>
      </div>
    </div>
  </section>
</BaseLayout>
