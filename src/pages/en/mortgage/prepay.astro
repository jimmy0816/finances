---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PrepayCalculator from '../../../components/calculators/PrepayCalculator';
const locale = 'en';
---
<BaseLayout
  title="Prepayment Calculator — Taiwan Mortgage"
  description="Calculate how much interest you save and how many years shorter your loan becomes with a lump sum or extra monthly payment."
  locale={locale}
>
  <div class="page-header" style="padding:48px 40px 40px;border-bottom:0.5px solid #E8DDD0;">
    <a href="/en/mortgage/" style="font-family:var(--font-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--color-text-muted);text-decoration:none;display:inline-block;margin-bottom:16px;">
      ← Mortgage Tools
    </a>
    <h1 style="font-family:var(--font-display);font-size:40px;font-weight:300;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;">
      Prepayment Calculator
    </h1>
    <p style="font-size:15px;color:#8A7E72;line-height:1.7;max-width:560px;font-weight:300;">
      How much interest does a lump-sum prepayment save? How many years shorter does it make your loan?
      Enter your loan info and instantly compare shorten-term vs. lower-payment options.
    </p>
  </div>

  <div style="padding:40px;max-width:1080px;margin:0 auto;">
    <PrepayCalculator client:load locale={locale} />
  </div>

  <!-- Guide -->
  <div style="padding:48px 40px;border-top:0.5px solid var(--color-border);background:var(--color-bg-card);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 style="font-size:18px;font-weight:400;color:var(--color-text-primary);margin-bottom:20px;padding-left:16px;border-left:3px solid var(--color-accent);">
        Which Option Should You Choose?
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0;border:0.5px solid var(--color-border);">
        <div style="padding:24px;border-right:0.5px solid var(--color-border);background:var(--color-bg-card);">
          <div style="font-size:24px;margin-bottom:10px;">⏩</div>
          <h3 style="font-size:14px;font-weight:500;margin-bottom:8px;">Shorten Term</h3>
          <p style="font-size:13px;color:var(--color-text-secondary);font-weight:300;line-height:1.7;">
            Same monthly payment, fewer months. Maximum interest savings. Best for stable income earners who want to pay off faster.
          </p>
        </div>
        <div style="padding:24px;background:var(--color-bg-card);">
          <div style="font-size:24px;margin-bottom:10px;">📉</div>
          <h3 style="font-size:14px;font-weight:500;margin-bottom:8px;">Lower Payment</h3>
          <p style="font-size:13px;color:var(--color-text-secondary);font-weight:300;line-height:1.7;">
            Same term, less monthly pressure. Slightly less interest saved. Best if you need monthly cash flow flexibility.
          </p>
        </div>
      </div>

      <div style="margin-top:32px;padding:16px 20px;background:var(--color-accent-bg);border-left:3px solid var(--color-accent);font-size:13px;color:var(--color-text-primary);line-height:1.75;">
        💡 <strong>Best Timing</strong>: Prepaying in the first third of your loan term maximizes interest savings, since most early payments are interest. Later prepayments have a smaller impact.
      </div>
    </div>
  </div>

  <div style="padding:24px 40px;border-top:0.5px solid var(--color-border);background:var(--color-bg);">
    <p style="font-size:11px;color:var(--color-text-muted);line-height:1.7;max-width:760px;margin:0 auto;font-family:var(--font-mono);letter-spacing:0.3px;">
      ⚠️ Disclaimer: Calculator uses equal payment (fixed monthly) basis. For educational purposes only.
      Actual terms, prepayment penalties, and interest calculations depend on your bank contract.
      Consult your bank or financial advisor before making financial decisions.
    </p>
  </div>
</BaseLayout>
