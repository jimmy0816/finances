---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AffordabilityCalculator from '../../../components/calculators/AffordabilityCalculator';
const locale = 'en';
---
<BaseLayout
  title="Home Affordability Calculator — Taiwan"
  description="Calculate your maximum mortgage and home purchase budget based on income, expenses, and down payment."
  locale={locale}
>
  <div class="page-header" style="padding:48px 40px 40px;border-bottom:0.5px solid #E8DDD0;">
    <a href="/en/mortgage/" style="font-family:var(--font-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--color-text-muted);text-decoration:none;display:inline-block;margin-bottom:16px;">
      ← Mortgage Tools
    </a>
    <h1 style="font-family:var(--font-display);font-size:40px;font-weight:300;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;">
      Affordability Calculator
    </h1>
    <p style="font-size:15px;color:#8A7E72;line-height:1.7;max-width:560px;font-weight:300;">
      Know your budget before you start house-hunting.
      Based on income, expenses, and down payment, calculate your maximum loan and affordable home price.
    </p>
  </div>

  <div style="padding:40px;max-width:1080px;margin:0 auto;">
    <AffordabilityCalculator client:load locale={locale} />
  </div>

  <div style="padding:48px 40px;border-top:0.5px solid var(--color-border);background:var(--color-bg-card);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 style="font-size:18px;font-weight:400;color:var(--color-text-primary);margin-bottom:20px;padding-left:16px;border-left:3px solid var(--color-accent);">
        How Is Affordability Calculated?
      </h2>
      <div style="font-size:14px;color:var(--color-text-primary);font-weight:300;line-height:1.8;">
        <ol style="margin-left:20px;margin-bottom:20px;">
          <li style="margin-bottom:8px;"><strong>Available Monthly Payment</strong> = (Income − Expenses) × Payment-to-Income Limit</li>
          <li style="margin-bottom:8px;"><strong>Maximum Loan</strong>: back-calculated from available payment using equal payment formula</li>
          <li style="margin-bottom:8px;"><strong>Affordable Price</strong> = Maximum Loan + Down Payment</li>
        </ol>
        <p style="color:var(--color-text-secondary);font-size:13px;">
          Banks typically cap at monthly payment ÷ income ≤ 40%. Financial advisors recommend 30–33% as a healthy target.
        </p>
      </div>
      <div style="margin-top:24px;padding:16px 20px;background:var(--color-accent-bg);border-left:3px solid var(--color-accent);font-size:13px;color:var(--color-text-primary);line-height:1.75;">
        💡 <strong>Note</strong>: Actual bank loan approval also depends on credit score, employment stability, other debts, and property valuation. This calculator shows a theoretical maximum.
      </div>
    </div>
  </div>

  <div style="padding:24px 40px;border-top:0.5px solid var(--color-border);background:var(--color-bg);">
    <p style="font-size:11px;color:var(--color-text-muted);line-height:1.7;max-width:760px;margin:0 auto;font-family:var(--font-mono);letter-spacing:0.3px;">
      ⚠️ Disclaimer: Uses equal payment method. For educational purposes only. Actual loan amounts depend on bank policy and individual credit. Not financial advice. Consult a loan specialist before purchasing.
    </p>
  </div>
</BaseLayout>
