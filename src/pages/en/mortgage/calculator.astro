---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../../components/calculators/MortgageCalculator';
const locale = 'en';
---
<BaseLayout title="Mortgage Payment Calculator — Taiwan" description="Free Taiwan mortgage calculator: monthly payment, total interest, amortization schedule. Fixed payment, fixed principal, grace period." locale={locale}>
  <div class="page-header" style="padding:48px 40px 40px;border-bottom:0.5px solid #E8DDD0;">
    <h1 style="font-family:var(--font-display);font-size:40px;font-weight:300;text-transform:uppercase;letter-spacing:2px;">Mortgage Calculator</h1>
    <p style="font-size:15px;color:#8A7E72;line-height:1.7;max-width:520px;font-weight:300;margin-top:12px;">Enter loan details to calculate monthly payment, total interest, and full amortization schedule.</p>
  </div>
  <div style="padding:40px;max-width:1080px;margin:0 auto;">
    <MortgageCalculator client:load locale={locale} />
  </div>
</BaseLayout>
