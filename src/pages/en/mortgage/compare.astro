---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const locale = 'en';
---
<BaseLayout title="Rate Comparison — Taiwan Mortgage" locale={locale}>
  <div style="background:var(--color-bg-card);border-bottom:0.5px solid var(--color-border);padding:48px 0;">
    <div class="container">
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--color-accent);margin-bottom:12px;">Mortgage Tools</div>
      <h1 style="font-size:32px;font-weight:400;letter-spacing:-0.5px;color:var(--color-text-primary);margin-bottom:8px;">Rate Comparison</h1>
      <p style="font-size:14px;color:var(--color-text-secondary);font-weight:300;">Coming soon — side-by-side comparison of multiple loan scenarios.</p>
    </div>
  </div>
  <section class="section">
    <div class="container">
      <div class="calc-container" style="padding:48px;text-align:center;">
        <span style="font-size:48px;display:block;margin-bottom:16px;">📊</span>
        <h2 style="font-size:20px;font-weight:400;margin-bottom:12px;">Mortgage Rate Comparison</h2>
        <p style="font-size:14px;color:var(--color-text-muted);font-weight:300;">Coming soon. Compare 2–4 bank loan scenarios side-by-side with total interest and monthly payments.</p>
      </div>
    </div>
  </section>
</BaseLayout>
