---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localePath } from '../../i18n/utils';
const locale = 'en';
---
<BaseLayout title="Taiwan Financial Calculators — Mortgage, Retirement, Salary" heroNav={true} locale={locale}>

  <!-- Hero -->
  <section class="hero-gradient" style="position:relative;min-height:80vh;display:flex;align-items:center;padding-top:var(--nav-height);">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%, rgba(224,112,32,0.10) 0%, transparent 60%);"></div>
    <div class="container" style="position:relative;padding-top:80px;padding-bottom:80px;">
      <div class="hero-eyebrow">finances.jimmy.vip</div>
      <h1 style="font-family:var(--font-display);font-size:clamp(40px,7vw,80px);font-weight:700;line-height:1.05;letter-spacing:-1px;color:#fff;max-width:700px;margin-bottom:24px;text-transform:uppercase;">
        Know your numbers, <span style="color:var(--color-accent);">make better decisions</span>
      </h1>
      <p class="hero-desc" style="font-size:16px;font-weight:300;color:rgba(255,255,255,0.65);max-width:480px;line-height:1.75;margin-bottom:40px;">
        Free Taiwan financial calculators — mortgage payments, retirement planning, take-home salary. No ads, no signup required.
      </p>
      <div class="hero-actions">
        <a href={localePath(locale, '/mortgage/calculator/')} class="btn-primary">Start Calculating</a>
        <a href={localePath(locale, '/blog/')} class="btn-secondary">{t(locale, 'nav.blog')}</a>
      </div>
    </div>
  </section>

  <!-- Tool Cards -->
  <section class="section" style="background:var(--color-bg);padding:64px 0;">
    <div class="container">
      <div class="section-label">Core Tools</div>
      <div class="section-title" style="margin-bottom:40px;">Three Financial Calculators</div>
      <div class="tool-cards">

        <a href={localePath(locale, '/mortgage/')} class="tool-card">
          <span class="tool-icon">🏠</span>
          <h3>Mortgage Calculator</h3>
          <p>Enter loan amount, rate, and term to instantly calculate monthly payment, total interest, and amortization schedule. Supports prepayment and multi-scenario comparison.</p>
          <span class="tool-card-link">Start Calculating →</span>
        </a>

        <a href={localePath(locale, '/retirement/')} class="tool-card">
          <span class="tool-icon">🌅</span>
          <h3>Retirement Planner</h3>
          <p>Set your target retirement age and lifestyle, calculate how much you need to save monthly, and identify your retirement gap.</p>
          <span class="tool-card-link">Start Calculating →</span>
        </a>

        <a href={localePath(locale, '/salary/')} class="tool-card">
          <span class="tool-icon">💼</span>
          <h3>Salary Calculator</h3>
          <p>Calculate your take-home pay after labor insurance, health insurance, income tax, and pension deductions under Taiwan's 2026 rates.</p>
          <span class="tool-card-link">Start Calculating →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Tagline Section -->
  <section style="background:var(--color-dark-bg);padding:80px 0;border-top:0.5px solid #111;">
    <div class="container" style="text-align:center;">
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--color-accent);margin-bottom:20px;">Our Position</div>
      <h2 style="font-family:var(--font-display);font-size:clamp(28px,4vw,52px);font-weight:700;text-transform:uppercase;letter-spacing:-0.5px;color:#fff;margin-bottom:16px;max-width:640px;margin-left:auto;margin-right:auto;">
        We don't sell financial products.<br/>We just help you crunch the numbers.
      </h2>
      <p style="font-size:14px;font-weight:300;color:rgba(255,255,255,0.45);max-width:440px;margin:0 auto 40px;line-height:1.7;">
        {t(locale, 'footer.disclaimer')}
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--color-accent);padding:64px 0;">
    <div class="container" style="display:flex;justify-content:space-between;align-items:center;gap:32px;flex-wrap:wrap;">
      <div>
        <h2 style="font-family:var(--font-display);font-size:36px;font-weight:700;text-transform:uppercase;letter-spacing:-0.5px;color:#fff;margin-bottom:8px;">Ready to calculate?</h2>
        <p style="font-size:14px;font-weight:300;color:rgba(255,255,255,0.8);">Free, no ads, no account needed.</p>
      </div>
      <a href={localePath(locale, '/mortgage/calculator/')} style="background:#fff;color:var(--color-accent);padding:16px 40px;font-size:14px;font-weight:500;text-decoration:none;transition:opacity 120ms;">
        Start Now
      </a>
    </div>
  </section>

</BaseLayout>
