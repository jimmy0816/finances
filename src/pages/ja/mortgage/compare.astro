---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const locale = 'ja';
---
<BaseLayout title="金利比較 — 台湾住宅ローン" locale={locale}>
  <div style="background:var(--color-bg-card);border-bottom:0.5px solid var(--color-border);padding:48px 0;">
    <div class="container">
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--color-accent);margin-bottom:12px;">住宅ローンツール</div>
      <h1 style="font-size:32px;font-weight:400;letter-spacing:-0.5px;color:var(--color-text-primary);margin-bottom:8px;">金利比較</h1>
      <p style="font-size:14px;color:var(--color-text-secondary);font-weight:300;">近日公開 — 複数ローンプランの並列比較。</p>
    </div>
  </div>
  <section class="section">
    <div class="container">
      <div class="calc-container" style="padding:48px;text-align:center;">
        <span style="font-size:48px;display:block;margin-bottom:16px;">📊</span>
        <h2 style="font-size:20px;font-weight:400;margin-bottom:12px;">住宅ローン金利比較</h2>
        <p style="font-size:14px;color:var(--color-text-muted);font-weight:300;">近日公開。2〜4行のローンプランを並べて総利息と月返済額を比較。</p>
      </div>
    </div>
  </section>
</BaseLayout>
