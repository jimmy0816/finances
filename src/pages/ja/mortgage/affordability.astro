---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AffordabilityCalculator from '../../../components/calculators/AffordabilityCalculator';
const locale = 'ja';
---
<BaseLayout title="購入可能額計算 — 台湾住宅ローン" description="収入・支出・頭金から最大借入額と購入可能な住宅価格を計算。返済比率安全指標付き。" locale={locale}>
  <div class="page-header" style="padding:48px 40px 40px;border-bottom:0.5px solid #E8DDD0;">
    <a href="/ja/mortgage/" style="font-family:var(--font-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--color-text-muted);text-decoration:none;display:inline-block;margin-bottom:16px;">
      ← 住宅ローンツール
    </a>
    <h1 style="font-family:var(--font-display);font-size:40px;font-weight:300;text-transform:uppercase;letter-spacing:2px;margin-bottom:12px;">購入可能額計算</h1>
    <p style="font-size:15px;color:#8A7E72;line-height:1.7;max-width:560px;font-weight:300;">
      物件探しの前に予算を把握しましょう。収入・支出・頭金から最大借入額と購入可能な価格を計算します。
    </p>
  </div>
  <div style="padding:40px;max-width:1080px;margin:0 auto;">
    <AffordabilityCalculator client:load locale={locale} />
  </div>
  <div style="padding:24px 40px;border-top:0.5px solid var(--color-border);background:var(--color-bg);">
    <p style="font-size:11px;color:var(--color-text-muted);line-height:1.7;max-width:760px;margin:0 auto;font-family:var(--font-mono);">
      ⚠️ 免責事項：元利均等払い方式を使用。教育・参考目的のみ。実際の融資可能額はお取引銀行の審査によります。
    </p>
  </div>
</BaseLayout>
