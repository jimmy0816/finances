---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../components/calculators/MortgageCalculator';
---
<BaseLayout title="房貸試算計算器" description="免費房貸月付試算，支援本息均攤、本金均攤、寬限期計算，含攤還明細表和圖表。">
  <div class="page-header" style="padding:48px 40px 40px;border-bottom:0.5px solid #E8DDD0;">
    <h1 style="font-family:var(--font-display);font-size:40px;font-weight:300;text-transform:uppercase;letter-spacing:2px;">房貸試算</h1>
    <p style="font-size:15px;color:#8A7E72;line-height:1.7;max-width:520px;font-weight:300;margin-top:12px;">輸入貸款條件，立即算出每月還款金額、總利息、攤還明細。</p>
  </div>
  <div style="padding:40px;max-width:1080px;margin:0 auto;">
    <MortgageCalculator client:load />
  </div>
</BaseLayout>
